@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Web.Virtualization
@using Microsoft.AspNetCore.Components

@page "/Dictionary"
@using MyDictionary.Models
@inject HttpClient Http


<div class="container mt-4">
    <h3 class="mb-4 text-primary">📖 My Little Dictionary</h3>

    <div class="row">
        <div class="col-md-7">
            <div class="shadow-sm p-3 mb-5 bg-white rounded" style="height:500px; overflow-y:auto; border: 1px solid #dee2e6;">
                <Virtualize Items="Terms" Context="term">
                    <div class="card mb-3 border-start border-primary border-4 shadow-sm">
                        <div class="card-body">
                            @if (SelectedTerm == term)
                            {
                                <div class="mb-2">
                                    <input @bind="EditModel.Term" class="form-control mb-2" placeholder="Term" />
                                    <input @bind="EditModel.Definition" class="form-control mb-2" placeholder="Definition" />
                                </div>
                                <button class="btn btn-success btn-sm" @onclick="Save">
                                    <i class="bi bi-check-lg"></i> Save
                                </button>
                                <button class="btn btn-outline-secondary btn-sm ms-2" @onclick="CancelEdit">Cancel</button>
                            }
                            else
                            {
                                <h5 class="card-title text-dark font-weight-bold">@term.Term</h5>
                                <p class="card-text text-muted">@term.Definition</p>
                                <hr />
                                <div class="d-flex justify-content-end">
                                    <button class="btn btn-outline-primary btn-sm me-2" @onclick="() => Edit(term)">
                                        Edit
                                    </button>
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => Delete(term)">
                                        Delete
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                </Virtualize>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card shadow-sm border-0 bg-light p-4">
                <h5 class="card-title mb-3">Add New Word</h5>
                <div class="mb-3">
                    <label class="form-label text-muted small">Term</label>
                    <input @bind="NewTermModel.Term" class="form-control shadow-none" placeholder="e.g. Apple" />
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted small">Definition</label>
                    <textarea @bind="NewTermModel.Definition" class="form-control shadow-none" rows="2" placeholder="e.g. A round red fruit"></textarea>
                </div>
                <button class="btn btn-primary w-100 py-2 mt-2 shadow-sm" @onclick="Add">
                    <strong>+ ADD WORD</strong>
                </button>
            </div>
        </div>
    </div>
</div>
@code {
    List<TermDto> Terms = new();
    TermDto? SelectedTerm = null;
    UpdateTermDto EditModel = new();
    CreateTermDto NewTermModel = new();

    string lookingFor = ""; 

    protected override async Task OnInitializedAsync()
    {
        Terms = await Http.GetFromJsonAsync<List<TermDto>>("api/terms");
    }

    async Task Add()
    {

        var response = await Http.PostAsJsonAsync("api/terms", NewTermModel);
        var created = await response.Content.ReadFromJsonAsync<TermDto>();

        //new added term to the list with id from the server
        Terms.Add(created);


        NewTermModel = new CreateTermDto();

        StateHasChanged();
    }

    void Edit(TermDto term)
    {
        SelectedTerm = term;
        EditModel = new UpdateTermDto
        {
            Term = term.Term,
            Definition = term.Definition
        };
    }

    void CancelEdit()
    {
        SelectedTerm = null;
    }

    async Task Save()
    {
        if (SelectedTerm is null)
            return;

        await Http.PutAsJsonAsync($"api/terms/{SelectedTerm.Id}", EditModel);

        // Update the term and definition in the list
        SelectedTerm.Term = EditModel.Term;
        SelectedTerm.Definition = EditModel.Definition;

        //Exit edit mode
        SelectedTerm = null; 
    }

    async Task Delete(TermDto term)
    {
        await Http.DeleteAsync($"api/terms/{term.Id}");
        Terms.Remove(term);
        StateHasChanged();
    }
}